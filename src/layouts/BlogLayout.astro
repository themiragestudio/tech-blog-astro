---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Giscus from '../components/Giscus.astro';

interface Props {
  title: string;
  description?: string;
  author?: string;
  date?: string;
  updatedDate?: string;
  tags?: string[];
  readingTime?: number;
  canonicalUrl?: string;
  ogImage?: string;
  enableComments?: boolean;
}

const { 
  title, 
  description = 'Mirage Studio 技术博客文章',
  author = 'Mirage Studio 团队',
  date = new Date().toISOString().split('T')[0],
  updatedDate,
  tags = [],
  readingTime = 5,
  canonicalUrl,
  ogImage,
  enableComments = true,
} = Astro.props;

// Format date
const formatDate = (dateStr: string) => {
  const dateObj = new Date(dateStr);
  return dateObj.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};

const formatDateTime = (dateStr: string) => {
  return new Date(dateStr).toISOString();
};
---

<BaseLayout 
  title={title} 
  description={description}
  canonicalUrl={canonicalUrl}
  ogImage={ogImage}
  ogType="article"
  author={author}
  publishedTime={formatDateTime(date)}
  modifiedTime={updatedDate ? formatDateTime(updatedDate) : undefined}
  tags={tags}
  showReadingProgress={true}
>
  <Nav showHomeLink={true} currentPage={Astro.url.pathname} />
  
  <main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
    <!-- Article Header -->
    <article class="prose prose-lg dark:prose-invert max-w-none">
      <header class="mb-12">
        <!-- Breadcrumb -->
        <nav class="mb-6" aria-label="面包屑导航">
          <ol class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400">
            <li>
              <a href="/blog" class="hover:text-brand dark:hover:text-brand-light transition-colors">首页</a>
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </li>
            <li>
              <a href="/blog/posts" class="hover:text-brand dark:hover:text-brand-light transition-colors">文章</a>
            </li>
            <li class="flex items-center">
              <svg class="w-4 h-4 mx-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </li>
            <li class="text-gray-900 dark:text-gray-300 font-medium" aria-current="page">{title}</li>
          </ol>
        </nav>

        <!-- Title -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white mb-6 leading-tight">
          {title}
        </h1>

        <!-- Meta Information -->
        <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600 dark:text-gray-400 mb-8">
          <!-- Author -->
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-brand to-brand-light flex items-center justify-center">
              <span class="text-white text-xs font-bold">{author.charAt(0)}</span>
            </div>
            <span class="font-medium">{author}</span>
          </div>
          
          <!-- Date -->
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <time datetime={formatDateTime(date)}>{formatDate(date)}</time>
            {updatedDate && (
              <>
                <span class="text-gray-400">•</span>
                <span class="text-gray-500">更新于 {formatDate(updatedDate)}</span>
              </>
            )}
          </div>
          
          <!-- Reading Time -->
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span>{readingTime} 分钟阅读</span>
          </div>
        </div>

        <!-- Tags -->
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {tags.map(tag => (
              <a 
                href={`/blog/tags/${tag}`} 
                class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-medium bg-gray-100 dark:bg-gray-800 text-gray-800 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors group"
              >
                <span class="text-brand dark:text-brand-light mr-1">#</span>
                {tag}
              </a>
            ))}
          </div>
        )}

        <!-- Description -->
        {description && (
          <div class="bg-gradient-to-r from-brand/5 to-brand-light/5 dark:from-brand/10 dark:to-brand-light/10 border-l-4 border-brand dark:border-brand-light rounded-r-lg p-6 mb-10">
            <p class="text-lg text-gray-700 dark:text-gray-300 italic m-0">
              {description}
            </p>
          </div>
        )}
      </header>

      {/* Article Content */}
      <div class="prose prose-lg dark:prose-invert prose-headings:font-bold prose-headings:text-gray-900 dark:prose-headings:text-white prose-h1:text-4xl prose-h2:text-3xl prose-h3:text-2xl prose-p:text-gray-700 dark:prose-p:text-gray-300 prose-a:text-brand dark:prose-a:text-brand-light prose-a:no-underline hover:prose-a:underline prose-strong:text-gray-900 dark:prose-strong:text-white prose-blockquote:border-brand dark:prose-blockquote:border-brand-light prose-blockquote:text-gray-600 dark:prose-blockquote:text-gray-400 prose-blockquote:bg-gray-50 dark:prose-blockquote:bg-gray-900/50 prose-code:text-gray-800 dark:prose-code:text-gray-200 prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-pre:bg-gray-900 dark:prose-pre:bg-gray-950 prose-pre:border prose-pre:border-gray-800 dark:prose-pre:border-gray-700 max-w-none">
        <slot />
      </div>

      {/* Article Footer */}
      <footer class="mt-16 pt-10 border-t border-gray-200 dark:border-gray-800">
        <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-8">
          <!-- Author Bio -->
          <div class="flex-1">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-brand to-brand-light flex items-center justify-center flex-shrink-0">
                <span class="text-white font-bold">{author.charAt(0)}</span>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900 dark:text-white mb-1">{author}</h3>
                <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                  Mirage Studio AI 团队成员，专注于工程实践和技术架构。
                </p>
                <div class="flex items-center gap-3 text-sm">
                  <a 
                    href="https://github.com/mirage-studio" 
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-500 dark:text-gray-400 hover:text-brand dark:hover:text-brand-light transition-colors"
                    aria-label="GitHub"
                  >
                    GitHub
                  </a>
                  <span class="text-gray-300 dark:text-gray-600">•</span>
                  <a 
                    href="https://twitter.com/mirage_studio" 
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-gray-500 dark:text-gray-400 hover:text-brand dark:hover:text-brand-light transition-colors"
                    aria-label="Twitter"
                  >
                    Twitter
                  </a>
                </div>
              </div>
            </div>
          </div>
          
          <!-- Actions -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a 
              href="/blog/posts" 
              class="inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-800 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              返回文章列表
            </a>
            <button
              onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
              class="inline-flex items-center justify-center gap-2 px-4 py-2.5 text-sm font-medium text-white bg-gradient-to-r from-brand to-brand-light rounded-lg hover:opacity-90 transition-opacity"
              aria-label="回到顶部"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
              </svg>
              回到顶部
            </button>
          </div>
        </div>

        <!-- Share & Metadata -->
        <div class="mt-10 pt-8 border-t border-gray-100 dark:border-gray-800">
          <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div class="text-sm text-gray-600 dark:text-gray-400">
              <p>文章发布于 <time datetime={formatDateTime(date)}>{formatDate(date)}</time></p>
              {updatedDate && (
                <p class="mt-1">最后更新于 <time datetime={formatDateTime(updatedDate)}>{formatDate(updatedDate)}</time></p>
              )}
              <p class="mt-1">版权声明：本文采用 <a 
                href="https://creativecommons.org/licenses/by-nc-sa/4.0/" 
                target="_blank"
                rel="noopener noreferrer"
                class="text-brand dark:text-brand-light hover:underline"
              >CC BY-NC-SA 4.0</a> 许可协议</p>
            </div>
            
            <div class="flex items-center gap-4">
              <span class="text-sm text-gray-500 dark:text-gray-400">分享：</span>
              <div class="flex items-center gap-3">
                <button
                  onclick="if (typeof window !== 'undefined') window.open('https://twitter.com/intent/tweet?text=' + encodeURIComponent(document.title) + '&url=' + encodeURIComponent(window.location.href), '_blank')"
                  class="text-gray-400 dark:text-gray-500 hover:text-[#1DA1F2] transition-colors"
                  aria-label="分享到 Twitter"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                  </svg>
                </button>
                <button
                  onclick="if (typeof window !== 'undefined') window.open('https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(window.location.href), '_blank')"
                  class="text-gray-400 dark:text-gray-500 hover:text-[#0A66C2] transition-colors"
                  aria-label="分享到 LinkedIn"
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                  </svg>
                </button>
                <button
                  onclick="if (typeof window !== 'undefined') navigator.clipboard.writeText(window.location.href).then(() => alert('链接已复制到剪贴板'))"
                  class="text-gray-400 dark:text-gray-500 hover:text-brand dark:hover:text-brand-light transition-colors"
                  aria-label="复制链接"
                >
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </footer>
      
      <!-- Comments Section (Giscus) -->
      {enableComments && <Giscus />}
    </article>
  </main>

  <Footer showBackToTop={false} showRssLink={true} />
</BaseLayout>

<!-- Table of Contents Script -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Generate table of contents from h2 and h3 headings
    const headings = document.querySelectorAll('article h2, article h3');
    if (headings.length > 2) {
      const toc = document.createElement('div');
      toc.className = 'toc-container bg-gray-50 dark:bg-gray-900/50 rounded-xl p-6 mb-10 border border-gray-200 dark:border-gray-800';
      
      const tocTitle = document.createElement('h3');
      tocTitle.className = 'font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2';
      tocTitle.innerHTML = `
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
        </svg>
        目录
      `;
      
      const tocList = document.createElement('ol');
      tocList.className = 'space-y-2 text-sm';
      
      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id = `heading-${index}`;
        }
        
        const listItem = document.createElement('li');
        const indent = heading.tagName === 'H3' ? 'ml-4' : '';
        
        listItem.innerHTML = `
          <a href="#${heading.id}" class="text-gray-600 dark:text-gray-400 hover:text-brand dark:hover:text-brand-light transition-colors ${indent} flex items-center gap-2">
            <span class="text-gray-400 dark:text-gray-600">${index + 1}.</span>
            ${heading.textContent}
          </a>
        `;
        
        tocList.appendChild(listItem);
      });
      
      toc.appendChild(tocTitle);
      toc.appendChild(tocList);
      
      const articleHeader = document.querySelector('article header');
      if (articleHeader && articleHeader.parentNode) {
        articleHeader.parentNode.insertBefore(toc, articleHeader.nextSibling);
      }
    }
    
    // Smooth scroll for anchor links within the article
    document.querySelectorAll('article a[href^="#"]').forEach(anchor => {
      anchor.addEventListener('click', function (this: HTMLAnchorElement, e: Event) {
        e.preventDefault();
        const targetId = this.getAttribute('href');
        if (targetId === '#') return;
        
        const targetElement = document.querySelector(targetId!);
        if (targetElement) {
          const nav = document.querySelector('nav');
          const headerHeight = nav ? nav.offsetHeight : 0;
          const targetPosition = targetElement.getBoundingClientRect().top + window.pageYOffset - headerHeight - 20;
          
          window.scrollTo({
            top: targetPosition,
            behavior: 'smooth'
          });
        }
      });
    });
  });
</script>

<style>
  /* Custom prose styles */
  .prose {
    --tw-prose-body: theme('colors.gray.700');
    --tw-prose-headings: theme('colors.gray.900');
    --tw-prose-lead: theme('colors.gray.600');
    --tw-prose-links: theme('colors.brand.600');
    --tw-prose-bold: theme('colors.gray.900');
    --tw-prose-counters: theme('colors.gray.500');
    --tw-prose-bullets: theme('colors.gray.300');
    --tw-prose-hr: theme('colors.gray.200');
    --tw-prose-quotes: theme('colors.gray.900');
    --tw-prose-quote-borders: theme('colors.brand.500');
    --tw-prose-captions: theme('colors.gray.500');
    --tw-prose-code: theme('colors.gray.900');
    --tw-prose-pre-code: theme('colors.gray.200');
    --tw-prose-pre-bg: theme('colors.gray.900');
    --tw-prose-th-borders: theme('colors.gray.300');
    --tw-prose-td-borders: theme('colors.gray.200');
  }
  
  .dark .prose {
    --tw-prose-body: theme('colors.gray.300');
    --tw-prose-headings: theme('colors.white');
    --tw-prose-lead: theme('colors.gray.400');
    --tw-prose-links: theme('colors.brand.400');
    --tw-prose-bold: theme('colors.white');
    --tw-prose-counters: theme('colors.gray.400');
    --tw-prose-bullets: theme('colors.gray.600');
    --tw-prose-hr: theme('colors.gray.700');
    --tw-prose-quotes: theme('colors.gray.100');
    --tw-prose-quote-borders: theme('colors.brand.400');
    --tw-prose-captions: theme('colors.gray.400');
    --tw-prose-code: theme('colors.gray.200');
    --tw-prose-pre-code: theme('colors.gray.300');
    --tw-prose-pre-bg: theme('colors.gray.950');
    --tw-prose-th-borders: theme('colors.gray.600');
    --tw-prose-td-borders: theme('colors.gray.700');
  }
  
  /* Custom heading anchors */
  .prose h2, .prose h3 {
    position: relative;
  }
  
  .prose h2:hover .heading-anchor,
  .prose h3:hover .heading-anchor {
    opacity: 1;
  }
  
  .heading-anchor {
    position: absolute;
    left: -1.5em;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0;
    transition: opacity 0.2s ease;
    color: theme('colors.brand.600');
  }
  
  .dark .heading-anchor {
    color: theme('colors.brand.400');
  }
  
  /* Code block styling */
  .prose pre {
    border-radius: 0.75rem;
    padding: 1.5rem;
    overflow-x: auto;
  }
  
  .prose code::before,
  .prose code::after {
    content: none;
  }
  
  /* Blockquote styling */
  .prose blockquote {
    font-style: normal;
    border-left-width: 4px;
    padding-left: 1.5rem;
    margin-left: 0;
    margin-right: 0;
  }
  
  /* Table styling */
  .prose table {
    width: 100%;
    border-collapse: collapse;
  }
  
  .prose th {
    text-align: left;
    font-weight: 600;
    padding: 0.75rem;
    border-bottom: 2px solid;
  }
  
  .prose td {
    padding: 0.75rem;
    border-bottom: 1px solid;
  }
</style>