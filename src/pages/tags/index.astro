---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// 收集所有标签及其数量
const tagMap = new Map();
allPosts.forEach(post => {
  if (post.data.tags) {
    post.data.tags.forEach(tag => {
      tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
    });
  }
});

// 按标签数量排序
const sortedTags = Array.from(tagMap.entries())
  .sort((a, b) => b[1] - a[1])
  .map(([tag, count]) => ({ name: tag, count }));

// 计算统计数据
const totalTags = sortedTags.length;
const totalPosts = allPosts.length;
const avgTagsPerPost = totalPosts > 0 
  ? (sortedTags.reduce((sum, tag) => sum + tag.count, 0) / totalPosts).toFixed(1)
  : 0;
---

<BaseLayout title="所有标签 | Mirage Studio 技术博客">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-2">
        所有标签
      </h1>
      <p class="text-gray-600 dark:text-gray-400">
        探索博客中的所有主题和分类
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <div class="text-2xl font-bold text-brand">{totalTags}</div>
        <div class="text-gray-600 dark:text-gray-400">标签总数</div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <div class="text-2xl font-bold text-brand">{totalPosts}</div>
        <div class="text-gray-600 dark:text-gray-400">文章总数</div>
      </div>
      <div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6">
        <div class="text-2xl font-bold text-brand">{avgTagsPerPost}</div>
        <div class="text-gray-600 dark:text-gray-400">平均标签数/文章</div>
      </div>
    </div>

    <div class="mb-6">
      <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200 mb-4">
        标签云
      </h2>
      <div class="flex flex-wrap gap-3">
        {sortedTags.map(({ name, count }) => (
          <a href={`/tags/${name}`} class="no-underline">
            <TagBadge 
              tag={name} 
              count={count} 
              size={count > 5 ? 'lg' : count > 2 ? 'md' : 'sm'}
              variant="solid"
            />
          </a>
        ))}
      </div>
    </div>

    <div class="bg-gray-50 dark:bg-gray-800 rounded-lg p-6">
      <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">
        标签统计详情
      </h3>
      <div class="space-y-4">
        {sortedTags.map(({ name, count }, index) => (
          <div class="flex items-center justify-between">
            <div class="flex items-center">
              <span class="text-gray-500 dark:text-gray-400 w-6 text-right mr-2">
                {index + 1}.
              </span>
              <a 
                href={`/tags/${name}`}
                class="text-gray-700 dark:text-gray-300 hover:text-brand dark:hover:text-brand font-medium"
              >
                {name}
              </a>
            </div>
            <div class="flex items-center">
              <span class="text-gray-600 dark:text-gray-400 mr-2">{count} 篇文章</span>
              <div class="w-24 bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                <div 
                  class="bg-brand h-2 rounded-full"
                  style={`width: ${(count / Math.max(...sortedTags.map(t => t.count)) * 100)}%`}
                ></div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-700">
      <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200 mb-3">
        如何使用标签
      </h3>
      <ul class="text-gray-600 dark:text-gray-400 space-y-2">
        <li>• 点击标签可以查看该标签下的所有文章</li>
        <li>• 标签大小表示文章数量，越大表示该主题越热门</li>
        <li>• 每个文章可以包含多个标签，方便交叉分类</li>
        <li>• 使用标签可以快速找到相关主题的内容</li>
      </ul>
    </div>
  </div>
</BaseLayout>