---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="文章列表 — Mirage Studio Tech Blog">
  <main class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-8">所有文章</h1>
    <ul class="space-y-8">
      {posts.map(post => (
        <li class="border-b border-gray-100 pb-8">
          <a href={`/blog/posts/${post.slug}/`} class="group">
            <h2 class="text-2xl font-semibold text-gray-900 group-hover:text-blue-600 mb-2">
              {post.data.title}
            </h2>
            <p class="text-gray-500 text-sm mb-2">
              {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
              {post.data.author && ` · ${post.data.author}`}
            </p>
            <p class="text-gray-600">{post.data.description}</p>
            <div class="flex gap-2 mt-3">
              {post.data.tags.map(tag => (
                <span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded">#{tag}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>
