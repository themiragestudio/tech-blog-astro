---
import ListLayout from '../../layouts/ListLayout.astro';
import PostCard from '../../components/PostCard.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection } from 'astro:content';

// Pagination configuration
const POSTS_PER_PAGE = 5;

// Get query parameters
const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get('page') || '1');
const tagFilter = url.searchParams.get('tag') || '';

// Get all blog posts
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Apply tag filter if specified
let filteredPosts = sortedPosts;
if (tagFilter) {
  filteredPosts = sortedPosts.filter(post => 
    post.data.tags && post.data.tags.includes(tagFilter)
  );
}

// Calculate pagination
const totalPosts = filteredPosts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);
const currentPage = Math.min(Math.max(page, 1), totalPages);
const startIndex = (currentPage - 1) * POSTS_PER_PAGE;
const endIndex = startIndex + POSTS_PER_PAGE;
const posts = filteredPosts.slice(startIndex, endIndex);

// Extract all tags with counts
const allTags = new Map<string, number>();
allPosts.forEach(post => {
  if (post.data.tags) {
    post.data.tags.forEach(tag => {
      allTags.set(tag, (allTags.get(tag) || 0) + 1);
    });
  }
});

// Sort tags by count
const sortedTags = Array.from(allTags.entries())
  .sort((a, b) => b[1] - a[1]);
---

<ListLayout 
  title="所有文章" 
  description={`共 ${totalPosts} 篇文章，涵盖 ${allTags.size} 个技术主题`}
  showHeader={true}
  totalItems={totalPosts}
  page={currentPage}
  totalPages={totalPages}
>
  <!-- Filters and Stats -->
  <div class="mb-12">
    <!-- Stats -->
    <div class="flex flex-wrap gap-6 mb-6">
      <div class="bg-gray-50 px-4 py-3 rounded-lg">
        <div class="text-2xl font-bold text-brand">{totalPosts}</div>
        <div class="text-sm text-gray-600">篇文章</div>
      </div>
      <div class="bg-gray-50 px-4 py-3 rounded-lg">
        <div class="text-2xl font-bold text-brand">{allTags.size}</div>
        <div class="text-sm text-gray-600">个标签</div>
      </div>
      <div class="bg-gray-50 px-4 py-3 rounded-lg">
        <div class="text-2xl font-bold text-brand">
          {new Date(allPosts[0]?.data.pubDate).getFullYear()}
        </div>
        <div class="text-sm text-gray-600">最新年份</div>
      </div>
      {totalPages > 1 && (
        <div class="bg-gray-50 px-4 py-3 rounded-lg">
          <div class="text-2xl font-bold text-brand">{currentPage}/{totalPages}</div>
          <div class="text-sm text-gray-600">当前页</div>
        </div>
      )}
    </div>
    
    <!-- All Tags -->
    {sortedTags.length > 0 && (
      <div>
        <h3 class="text-sm font-medium text-gray-700 mb-3">所有标签</h3>
        <div class="flex flex-wrap gap-2">
          {sortedTags.map(([tag, count]) => (
            <TagBadge 
              tag={tag} 
              count={count}
              href={`/blog/tags/${tag}`}
              size="sm"
              variant="outline"
            />
          ))}
        </div>
      </div>
    )}
  </div>

  <!-- Posts Grid -->
  <div class="grid gap-8">
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        description={post.data.description}
        date={post.data.pubDate.toISOString()}
        author={post.data.author}
        tags={post.data.tags}
        slug={post.slug}
        readingTime={post.data.readingTime}
      />
    ))}
  </div>

  <!-- Empty State -->
  {posts.length === 0 && (
    <div class="text-center py-12">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto text-gray-400 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <p class="text-gray-500">暂无文章</p>
      <p class="text-sm text-gray-400 mt-2">稍后再来看看吧</p>
    </div>
  )}

  <!-- Pagination Info -->
  {totalPages > 1 && (
    <div class="mt-8 pt-6 border-t border-gray-200 text-center">
      <p class="text-sm text-gray-600">
        显示第 {startIndex + 1}-{Math.min(endIndex, totalPosts)} 篇文章，共 {totalPosts} 篇
      </p>
      <p class="text-xs text-gray-500 mt-1">
        每页显示 {POSTS_PER_PAGE} 篇文章
      </p>
    </div>
  )}
</ListLayout>
