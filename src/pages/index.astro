---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<BaseLayout title="Mirage Studio Tech Blog">
  <main class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Mirage Studio 技术博客</h1>
    <p class="text-lg text-gray-600 mb-12">
      记录 Mirage Studio AI 团队的技术探索、项目历程与工程实践。
    </p>

    <section>
      <h2 class="text-2xl font-semibold text-gray-900 mb-6">最新文章</h2>
      <ul class="space-y-8">
        {recentPosts.map(post => (
          <li class="border-b border-gray-100 pb-8">
            <a href={`/blog/posts/${post.slug}/`} class="group">
              <h3 class="text-xl font-semibold text-gray-900 group-hover:text-blue-600 mb-2">
                {post.data.title}
              </h3>
              <p class="text-gray-500 text-sm mb-2">
                {post.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
                {post.data.author && ` · ${post.data.author}`}
              </p>
              <p class="text-gray-600">{post.data.description}</p>
            </a>
          </li>
        ))}
      </ul>
      <div class="mt-8">
        <a href="/blog/posts" class="text-blue-600 hover:underline">查看全部文章 →</a>
      </div>
    </section>
  </main>
</BaseLayout>
