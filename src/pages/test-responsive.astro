---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="响应式布局测试" description="测试技术博客的响应式布局">
  <Nav showHomeLink={true} />
  
  <main class="max-w-6xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-900 dark:text-white mb-8">响应式布局测试</h1>
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
      <!-- Mobile Preview -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          移动端预览
        </h2>
        <div class="relative">
          <div class="w-full max-w-[320px] mx-auto border-8 border-gray-800 rounded-[2rem] shadow-2xl">
            <div class="bg-gray-800 h-6 rounded-t-[1.5rem] flex items-center justify-center">
              <div class="w-16 h-1 bg-gray-600 rounded-full"></div>
            </div>
            <div class="bg-white h-[600px] overflow-y-auto p-4">
              <!-- Mobile Nav -->
              <div class="flex items-center justify-between mb-6">
                <div class="font-bold text-lg">Mirage Studio</div>
                <button class="text-gray-600">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                  </svg>
                </button>
              </div>
              
              <!-- Mobile Content -->
              <div class="space-y-4">
                <div class="bg-gradient-to-r from-brand to-brand-light rounded-lg p-4 text-white">
                  <h3 class="font-bold mb-2">欢迎来到技术博客</h3>
                  <p class="text-sm opacity-90">移动端体验优化</p>
                </div>
                
                <div class="border border-gray-200 rounded-lg p-4">
                  <h4 class="font-semibold text-gray-900 mb-2">文章标题示例</h4>
                  <p class="text-sm text-gray-600 line-clamp-2">这是一个在移动设备上显示的示例文章卡片，展示了响应式设计的效果。</p>
                  <div class="flex items-center gap-2 mt-3 text-xs text-gray-500">
                    <span>2026-03-11</span>
                    <span>•</span>
                    <span>5分钟阅读</span>
                  </div>
                </div>
                
                <div class="border border-gray-200 rounded-lg p-4">
                  <h4 class="font-semibold text-gray-900 mb-2">另一个示例</h4>
                  <p class="text-sm text-gray-600 line-clamp-2">确保在小屏幕上内容清晰可读，触摸目标足够大。</p>
                  <div class="flex flex-wrap gap-1 mt-3">
                    <span class="px-2 py-1 bg-gray-100 text-gray-800 text-xs rounded">标签</span>
                    <span class="px-2 py-1 bg-gray-100 text-gray-800 text-xs rounded">示例</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Desktop Preview -->
      <div class="bg-white dark:bg-gray-900 rounded-xl border border-gray-200 dark:border-gray-800 p-6">
        <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          桌面端预览
        </h2>
        <div class="relative">
          <div class="w-full border-4 border-gray-800 rounded-lg shadow-2xl">
            <div class="bg-gray-800 h-6 rounded-t-lg flex items-center justify-between px-4">
              <div class="flex items-center gap-2">
                <div class="w-3 h-3 rounded-full bg-red-500"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
                <div class="w-3 h-3 rounded-full bg-green-500"></div>
              </div>
              <div class="text-xs text-gray-300">mirage.studio/blog</div>
              <div class="w-16"></div>
            </div>
            <div class="bg-white h-[400px] overflow-hidden">
              <!-- Desktop Nav -->
              <div class="border-b border-gray-200 px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-8">
                  <div class="font-bold text-lg">Mirage Studio Blog</div>
                  <nav class="hidden md:flex gap-6 text-sm">
                    <a href="#" class="text-gray-600 hover:text-brand">首页</a>
                    <a href="#" class="text-gray-600 hover:text-brand">文章</a>
                    <a href="#" class="text-gray-600 hover:text-brand">标签</a>
                    <a href="#" class="text-gray-600 hover:text-brand">关于</a>
                  </nav>
                </div>
                <div class="flex items-center gap-4">
                  <button class="text-gray-600">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                    </svg>
                  </button>
                  <button class="px-4 py-2 bg-gradient-to-r from-brand to-brand-light text-white text-sm rounded-lg">
                    订阅
                  </button>
                </div>
              </div>
              
              <!-- Desktop Content -->
              <div class="p-6">
                <div class="grid grid-cols-3 gap-6">
                  <div class="col-span-2">
                    <div class="border border-gray-200 rounded-xl p-6 mb-6">
                      <h3 class="text-2xl font-bold text-gray-900 mb-3">桌面端布局示例</h3>
                      <p class="text-gray-600 mb-4">在桌面设备上，我们使用多列布局、更大的字体和更复杂的组件排列。</p>
                      <div class="flex items-center gap-4 text-sm text-gray-500">
                        <span>作者: Mirage Studio</span>
                        <span>•</span>
                        <span>发布于: 2026-03-11</span>
                        <span>•</span>
                        <span>阅读时间: 5分钟</span>
                      </div>
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                      <div class="border border-gray-200 rounded-lg p-4">
                        <h4 class="font-semibold mb-2">响应式设计</h4>
                        <p class="text-sm text-gray-600">确保在不同屏幕尺寸上都有良好的用户体验。</p>
                      </div>
                      <div class="border border-gray-200 rounded-lg p-4">
                        <h4 class="font-semibold mb-2">性能优化</h4>
                        <p class="text-sm text-gray-600">快速加载，流畅交互。</p>
                      </div>
                    </div>
                  </div>
                  
                  <div class="space-y-4">
                    <div class="bg-gray-50 rounded-lg p-4">
                      <h4 class="font-semibold mb-2">侧边栏</h4>
                      <p class="text-sm text-gray-600">在桌面端显示额外信息和功能。</p>
                    </div>
                    <div class="bg-gray-50 rounded-lg p-4">
                      <h4 class="font-semibold mb-2">标签云</h4>
                      <div class="flex flex-wrap gap-2">
                        <span class="px-2 py-1 bg-white border border-gray-200 text-xs rounded">Astro</span>
                        <span class="px-2 py-1 bg-white border border-gray-200 text-xs rounded">Tailwind</span>
                        <span class="px-2 py-1 bg-white border border-gray-200 text-xs rounded">React</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Layout Components Test -->
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">布局组件测试</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- BaseLayout Test -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">BaseLayout.astro</h3>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              HTML5 文档结构
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Meta 标签 (SEO)
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Open Graph 标签
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              暗色模式支持
            </li>
          </ul>
        </div>
        
        <!-- Nav Test -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Nav.astro</h3>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              响应式导航栏
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              移动端菜单
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              品牌色应用
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              外部链接图标
            </li>
          </ul>
        </div>
        
        <!-- Footer Test -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">Footer.astro</h3>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              版权信息
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              链接分组
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              社交媒体链接
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              RSS 订阅
            </li>
          </ul>
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
        <!-- BlogLayout Test -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">BlogLayout.astro</h3>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              文章详情布局
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Typography 样式
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              目录生成
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              分享功能
            </li>
          </ul>
        </div>
        
        <!-- ListLayout Test -->
        <div class="border border-gray-200 dark:border-gray-800 rounded-xl p-6">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">ListLayout.astro</h3>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              列表页布局
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              侧边栏支持
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              分页功能
            </li>
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              过滤和排序
            </li>
          </ul>
        </div>
      </div>
    </div>
    
    <!-- Brand Color Test -->
    <div class="mb-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">品牌色测试</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div class="bg-brand-50 dark:bg-brand-900/20 p-4 rounded-lg text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-brand-50 dark:bg-brand-900 rounded-lg"></div>
          <div class="text-xs font-medium">50 / #F5F3FF</div>
        </div>
        <div class="bg-brand-100 dark:bg-brand-800/20 p-4 rounded-lg text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-brand-100 dark:bg-brand-800 rounded-lg"></div>
          <div class="text-xs font-medium">100 / #EDE9FE</div>
        </div>
        <div class="bg-brand-400 dark:bg-brand-600/20 p-4 rounded-lg text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-brand-400 dark:bg-brand-600 rounded-lg"></div>
          <div class="text-xs font-medium">400 / #A78BFA</div>
        </div>
        <div class="bg-brand-600 dark:bg-brand-400/20 p-4 rounded-lg text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-brand-600 dark:bg-brand-400 rounded-lg"></div>
          <div class="text-xs font-medium">600 / #7C3AED</div>
          <div class="text-xs text-gray-500 mt-1">主品牌色</div>
        </div>
        <div class="bg-brand-800 dark:bg-brand-200/20 p-4 rounded-lg text-center">
          <div class="w-12 h-12 mx-auto mb-2 bg-brand-800 dark:bg-brand-200 rounded-lg"></div>
          <div class="text-xs font-medium">800 / #5B21B6</div>
        </div>
      </div>
    </div>
    
    <!-- Responsive Breakpoints Test -->
    <div>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">响应式断点测试</h2>
      <div class="bg-gray-50 dark:bg-gray-900/50 rounded-xl p-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <div class="bg-white dark:bg-gray-800 p-4 rounded-lg text-center">
            <div class="text-sm font-semibold text-gray-900 dark:text-white">移动端</div>
            <div class="text-xs text-gray-500 mt-1">&lt; 640px</div>
            <div class="mt-2 text-sm">单列布局</div>
          </div>
          <div class="bg-white dark:bg-gray-800 p-4 rounded-lg text-center">
            <div class="text-sm font-semibold text-gray-900 dark:text-white">平板</div>
            <div class="text-xs text-gray-500 mt-1">640px - 1024px</div>
            <div class="mt-2 text-sm">两列布局</div>
          </div>
          <div class="bg-white dark:bg-gray-800 p-4 rounded-lg text-center">
            <div class="text-sm font-semibold text-gray-900 dark:text-white">桌面端</div>
            <div class="text-xs text-gray-500 mt-1">1024px - 1280px</div>
            <div class="mt-2 text-sm">三列布局</div>
          </div>
          <div class="bg-white dark:bg-gray-800 p-4 rounded-lg text-center">
            <div class="text-sm font-semibold text-gray-900 dark:text-white">大桌面</div>
            <div class="text-xs text-gray-500 mt-1">&gt; 1280px</div>
            <div class="mt-2 text-sm">四列布局</div>
          </div>
        </div>
        
        <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-800">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">当前视口信息</h3>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="bg-white dark:bg-gray-800 p-4 rounded-lg">
              <div class="text-sm font-medium text-gray-900 dark:text-white">宽度</div>
              <div id="viewport-width" class="text-2xl font-bold text-brand dark:text-brand-light mt-2">--</div>
            </div>
            <div class="bg-white dark:bg-gray-800 p-4 rounded-lg">
              <div class="text-sm font-medium text-gray-900 dark:text-white">高度</div>
              <div id="viewport-height" class="text-2xl font-bold text-brand dark:text-brand-light mt-2">--</div>
            </div>
            <div class="bg-white dark:bg-gray-800 p-4 rounded-lg">
              <div class="text-sm font-medium text-gray-900 dark:text-white">断点</div>
              <div id="current-breakpoint" class="text-2xl font-bold text-brand dark:text-brand-light mt-2">--</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <Footer showBackToTop={true} showRssLink={true} />

  <script>
    // Viewport information
    function updateViewportInfo() {
      const width = window.innerWidth;
      const height = window.innerHeight;
      
      const widthElement = document.getElementById('viewport-width');
      const heightElement = document.getElementById('viewport-height');
      const breakpointElement = document.getElementById('current-breakpoint');
      
      if (widthElement) widthElement.textContent = `${width}px`;
      if (heightElement) heightElement.textContent = `${height}px`;
      
      let breakpoint = '移动端';
      if (width >= 1280) breakpoint = '大桌面';
      else if (width >= 1024) breakpoint = '桌面端';
      else if (width >= 640) breakpoint = '平板';
      
      if (breakpointElement) breakpointElement.textContent = breakpoint;
    }
    
    // Initial update
    updateViewportInfo();
    
    // Update on resize
    window.addEventListener('resize', updateViewportInfo);
    
    // Test dark mode toggle
    document.addEventListener('DOMContentLoaded', () => {
      const darkModeButton = document.querySelector('button[aria-label="切换主题"]');
      if (darkModeButton) {
        darkModeButton.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }
    });
  </script>
</BaseLayout>