---
interface Props {
  tag: string;
  count?: number;
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'outline' | 'solid';
  href?: string;
}

const { 
  tag, 
  count,
  size = 'md',
  variant = 'default',
  href
} = Astro.props;

// Size classes
const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
  lg: 'px-4 py-1.5 text-base'
};

// Variant classes
const variantClasses = {
  default: 'bg-gray-100 text-gray-800 hover:bg-gray-200 hover:text-gray-900',
  outline: 'bg-transparent border border-gray-300 text-gray-700 hover:border-brand hover:text-brand',
  solid: 'bg-brand text-white hover:bg-purple-700'
};

// Combined classes
const badgeClasses = `inline-flex items-center gap-1 rounded-full font-medium transition-colors ${sizeClasses[size]} ${variantClasses[variant]}`;
---

{
  href ? (
    <a href={href} class={badgeClasses}>
      <span>#{tag}</span>
      {count !== undefined && (
        <span class="text-xs opacity-75">({count})</span>
      )}
    </a>
  ) : (
    <span class={badgeClasses}>
      <span>#{tag}</span>
      {count !== undefined && (
        <span class="text-xs opacity-75">({count})</span>
      )}
    </span>
  )
}