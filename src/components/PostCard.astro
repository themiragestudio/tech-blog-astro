---
interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
  tags?: string[];
  slug: string;
  readingTime?: string | number;
  highlightQuery?: string;
}

const { 
  title, 
  description, 
  date, 
  author = 'Mirage Studio 团队',
  tags = [],
  slug,
  readingTime = '5分钟',
  highlightQuery = ''
} = Astro.props;

// Format reading time
const formatReadingTime = (time: string | number | undefined): string => {
  if (typeof time === 'number') {
    return `${time}分钟`;
  }
  return time || '5分钟';
};

// Format date
const formatDate = (dateStr: string) => {
  const dateObj = new Date(dateStr);
  return dateObj.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
};

// Highlight text function
const highlightText = (text: string, query: string) => {
  if (!query || !text) return text;
  
  const normalizedQuery = query.toLowerCase();
  const normalizedText = text.toLowerCase();
  const index = normalizedText.indexOf(normalizedQuery);
  
  if (index === -1) return text;
  
  const before = text.substring(0, index);
  const match = text.substring(index, index + query.length);
  const after = text.substring(index + query.length);
  
  return `${before}<mark class="bg-yellow-200 dark:bg-yellow-800 px-1 rounded">${match}</mark>${after}`;
};
---

<article class="article-card group">
  <!-- Header -->
  <header class="mb-4">
    <a href={`/blog/posts/${slug}`} class="block" aria-label={`阅读文章: ${title}`}>
      <h2 class="text-xl font-semibold text-gray-900 mb-2 group-hover:text-brand transition-colors" set:html={highlightQuery ? highlightText(title, highlightQuery) : title}></h2>
    </a>
    
    <!-- Meta information -->
    <div class="article-meta">
      <div class="flex items-center gap-1 text-sm text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        <span>{author}</span>
      </div>
      
      <div class="flex items-center gap-1 text-sm text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <time datetime={date}>{formatDate(date)}</time>
      </div>
      
      <div class="flex items-center gap-1 text-sm text-gray-500">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <span>{formatReadingTime(readingTime)}</span>
      </div>
    </div>
  </header>
  
  <!-- Description -->
  <p class="text-gray-600 line-clamp-2 mb-4" set:html={highlightQuery ? highlightText(description, highlightQuery) : description}>
  
  <!-- Tags -->
  {tags.length > 0 && (
    <div class="article-tags">
      {tags.slice(0, 3).map(tag => (
        <a 
          href={`/blog/tags/${tag}`} 
          class="article-tag hover:bg-gray-200 hover:text-gray-900 transition-colors"
        >
          #{tag}
        </a>
      ))}
      {tags.length > 3 && (
        <span class="article-tag text-gray-500">
          +{tags.length - 3}
        </span>
      )}
    </div>
  )}
  
  <!-- Read more link -->
  <div class="mt-4 pt-4 border-t border-gray-100">
    <a 
      href={`/blog/posts/${slug}`} 
      class="inline-flex items-center gap-1 text-sm font-medium text-brand hover:text-purple-700 transition-colors"
    >
      阅读全文
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
      </svg>
    </a>
  </div>
</article>