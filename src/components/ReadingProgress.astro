---
/**
 * ReadingProgress.astro
 * 阅读进度指示器组件
 * - 固定在页面顶部
 * - 实时显示阅读进度
 * - 平滑动画效果
 * - 响应式设计
 */

interface Props {
  color?: string;
  height?: string;
  showPercentage?: boolean;
}

const { 
  color = 'from-brand to-brand-light',
  height = 'h-1',
  showPercentage = false
} = Astro.props;
---

<div 
  class="reading-progress-container fixed top-0 left-0 right-0 z-[60] pointer-events-none"
  role="progressbar"
  aria-label="阅读进度"
  aria-valuenow="0"
  aria-valuemin="0"
  aria-valuemax="100"
>
  <!-- Progress Bar -->
  <div 
    class={`reading-progress-bar ${height} bg-gradient-to-r ${color} w-0 transition-[width] duration-100 ease-out`}
    id="reading-progress-bar"
  ></div>
  
  <!-- Percentage Display (optional) -->
  {showPercentage && (
    <div 
      class="reading-progress-percentage fixed top-4 right-4 bg-gray-900/80 dark:bg-gray-100/80 text-white dark:text-gray-900 text-xs font-medium px-2 py-1 rounded-full opacity-0 transition-opacity duration-300 pointer-events-none"
      id="reading-progress-percentage"
    >
      0%
    </div>
  )}
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const progressBar = document.getElementById('reading-progress-bar');
    const progressPercentage = document.getElementById('reading-progress-percentage');
    const container = document.querySelector('.reading-progress-container');
    
    if (!progressBar) return;
    
    let ticking = false;
    
    const updateProgress = () => {
      // Calculate scroll progress
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      const docHeight = document.documentElement.scrollHeight;
      const winHeight = window.innerHeight;
      const scrollPercent = (scrollTop / (docHeight - winHeight)) * 100;
      const clampedPercent = Math.min(100, Math.max(0, scrollPercent));
      
      // Update progress bar
      progressBar.style.width = `${clampedPercent}%`;
      
      // Update ARIA attributes
      if (container) {
        container.setAttribute('aria-valuenow', clampedPercent.toFixed(0));
      }
      
      // Update percentage display if present
      if (progressPercentage) {
        progressPercentage.textContent = `${Math.round(clampedPercent)}%`;
        progressPercentage.style.opacity = scrollPercent > 5 ? '1' : '0';
      }
      
      ticking = false;
    };
    
    const onScroll = () => {
      if (!ticking) {
        requestAnimationFrame(updateProgress);
        ticking = true;
      }
    };
    
    // Initial update
    updateProgress();
    
    // Listen for scroll events
    window.addEventListener('scroll', onScroll, { passive: true });
    
    // Update on resize (document height may change)
    window.addEventListener('resize', updateProgress, { passive: true });
  });
</script>

<style>
  .reading-progress-bar {
    transform-origin: left;
    will-change: width;
  }
  
  /* Smooth gradient animation on hover (optional enhancement) */
  .reading-progress-bar {
    background-size: 200% 100%;
    animation: gradientShift 3s ease infinite;
  }
  
  @keyframes gradientShift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }
</style>
