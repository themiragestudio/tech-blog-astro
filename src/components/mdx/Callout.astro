---
interface Props {
  type?: 'info' | 'warning' | 'danger';
}

const { type = 'info' } = Astro.props;

const styles = {
  info: 'bg-blue-50 border-blue-400 text-blue-900 dark:bg-blue-900/20 dark:border-blue-600 dark:text-blue-200',
  warning: 'bg-yellow-50 border-yellow-400 text-yellow-900 dark:bg-yellow-900/20 dark:border-yellow-600 dark:text-yellow-200',
  danger: 'bg-red-50 border-red-400 text-red-900 dark:bg-red-900/20 dark:border-red-600 dark:text-red-200',
};

const icons = {
  info: 'ℹ️',
  warning: '⚠️',
  danger: '❌',
};

const titles = {
  info: '信息',
  warning: '警告',
  danger: '危险',
};
---

<div class={`border-l-4 p-4 my-6 rounded-r-lg ${styles[type]}`}>
  <div class="flex items-start">
    <span class="mr-2 text-lg">{icons[type]}</span>
    <div>
      <div class="font-semibold mb-1">{titles[type]}</div>
      <div class="prose prose-sm max-w-none">
        <slot />
      </div>
    </div>
  </div>
</div>